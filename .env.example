# ---- Server ----
PORT=5050
NODE_ENV=development

# ---- Supabase (Postgres + storage) ----
# Leave BLANK to run with the in-memory demo store (data resets on restart).
# Set these to persist to a real Supabase project.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Clerk auth ----
# Leave BLANK in dev to use the built-in dev-admin bypass (no login required).
# Set in production; server refuses to start in prod without CLERK_SECRET_KEY.
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# Comma-separated emails that bootstrap as manager_admin on first login.
ADMIN_EMAILS=ecomley45@gmail.com
